const { PutObjectCommand, HeadObjectCommand } = require("@aws-sdk/client-s3");
const uploadLocal = require("./uploadLocal");

/**
 * Upload a file buffer to S3 or local disk (fallback).
 * @param {Object} file - Multer file object
 * @param {string} folder - Target folder path or full key
 * @returns {Promise<string>} - Public URL or local path
 */
const uploadToS3 = async (file, folder = "uploads") => {
  // Check if AWS credentials are configured
  const hasAWSConfig = process.env.AWS_ACCESS_KEY_ID && process.env.AWS_SECRET_ACCESS_KEY && process.env.AWS_REGION;

  if (!hasAWSConfig) {
    console.log("[Upload] AWS credentials not configured. Using local file storage.");
    return uploadLocal(file, folder);
  }

  const s3 = require("../config/s3");
  const bucket = process.env.AWS_BUCKET_NAME;
  const region = process.env.AWS_REGION;

  // Logic: If 'folder' looks like a full path (contains extension), use it as the key.
  // Otherwise, construct a key with a timestamp.
  let key = folder;
  if (!folder.includes(".")) {
    const timestamp = Date.now();
    const sanitizedFileName = file.originalname.replace(/[^a-zA-Z0-9.\-_]/g, "_");
    key = `${folder}/${timestamp}_${sanitizedFileName}`;
  }

  try {
    // 1. Perform the Upload
    const uploadCommand = new PutObjectCommand({
      Bucket: bucket,
      Key: key,
      Body: file.buffer,
      ContentType: file.mimetype,
    });

    await s3.send(uploadCommand);
    console.log(`[S3] Uploaded: ${key}`);

    // 2. VERIFICATION: Confirm the file actually exists on S3
    const checkCommand = new HeadObjectCommand({
      Bucket: bucket,
      Key: key,
    });

    await s3.send(checkCommand);
    console.log(`[S3] Verified: File exists at ${key}`);

    // 3. Return the Public URL
    return `https://${bucket}.s3.${region}.amazonaws.com/${key}`;

  } catch (error) {
    console.error("[S3] Upload or Verification failed:", error.message);
    throw new Error(`S3 Upload Failed: ${error.message}`);
  }
};

module.exports = uploadToS3;